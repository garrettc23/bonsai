# Required — Bonsai uses Claude Opus 4.7 for analysis, appeal,
# and negotiation. Copy this file to `.env` and fill in your real key. Bun
# auto-loads `.env` on `bun run serve`; the file is gitignored so the secret
# never lands in version control.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — if unset, the email loop uses MockEmailClient (in-memory thread state)
# When set, ResendEmailClient actually delivers outbound mail.
# RESEND_API_KEY=re_...
# RESEND_FROM="Bonsai Appeals <appeals@yourdomain.com>"

# Optional — Svix signing secret for the Resend inbound webhook
# (POST /webhooks/resend-inbound). When set, every inbound is verified
# via constant-time HMAC with a 5-minute replay window.
# Production: REQUIRED — handler returns 500 if NODE_ENV=production and this
# is missing (fail-closed).
# Local dev: handler accepts unsigned payloads with a console warning so you
# can curl the endpoint from a tunnel without round-tripping Svix.
# RESEND_WEBHOOK_SECRET=whsec_...

# Optional — unlocks the read-only echo route at
# POST /webhooks/resend-inbound/echo?debug_token=<this-value>. The echo
# route reports whether a signed payload would verify (and how the thread
# would correlate) without mutating any state. Used by
# `scripts/resend-inbound-smoke.sh --echo` to verify a fresh deploy.
# With this env unset, the echo route is a hard 404.
# BONSAI_WEBHOOK_DEBUG_TOKEN=

# Optional — ElevenLabs Conversational AI for real phone dialing.
# The simulator (src/voice/simulator.ts) runs whenever any of these is unset.
# All four together flip the orchestrator over to real outbound calls.
# ELEVENLABS_API_KEY=...
# ELEVENLABS_TWILIO_PHONE_NUMBER_ID=...    # ID from GET /v1/convai/twilio/phone-numbers
# ELEVENLABS_WEBHOOK_BASE=https://your-tunnel.ngrok.app   # public root; agent posts back to <base>/webhooks/voice/<tool>
# ELEVENLABS_WEBHOOK_SECRET=...             # Bearer secret for inbound server-tool callbacks

# Optional — voice cost gates.
# Per-user daily call cap (sliding-window). Default 5.
# BONSAI_VOICE_DAILY_LIMIT=5
# Operator-wide daily ceiling in USD. Default 50. The dial endpoint refuses to
# place a call when (today_spend + max_estimate) > this cap.
# BONSAI_VOICE_DAILY_BUDGET_USD=50
# When true, /api/voice/dial logs the call it WOULD place and returns a
# synthetic conversation_id without invoking ElevenLabs. Lets agents and
# the smoke script exercise the wiring without burning Twilio minutes.
# VOICE_DRY_RUN=false

# Optional — override HTTP port for the web UI (default 3333)
# PORT=3333

# Optional — directory where Bonsai stores SQLite + per-user files.
# Local dev: defaults to <repo>/out (no need to set).
# Production (Railway / Fly / any container): point at the mounted
# persistent volume, e.g. /app/data, so signups + bills survive deploys.
# BONSAI_DATA_DIR=/app/data

# Optional — set to "production" on hosted deploys. Flips on:
#   - the `Secure` flag on session cookies (HTTPS-only)
#   - fail-closed svix verification on the Resend inbound webhook
# Local dev: leave unset.
# NODE_ENV=production

# Optional — public branding rendered by the SPA + landing + error pages.
# These are surfaced via GET /api/public-config (unauthenticated) so the
# front-end can write the right "Contact" mailto and copy without baking
# the operator's address into the source. OSS forks override per-deploy.
# Unset values render as nothing (the footer link hides itself).
# BONSAI_SUPPORT_EMAIL=support@your-bonsai-domain.com
# BONSAI_PUBLIC_DOMAIN=bonsai.example.com

# OPTIONAL — disaster recovery.
# Nightly tarball backup of $BONSAI_DATA_DIR to any S3-compatible object
# store (Backblaze B2, Cloudflare R2, AWS S3, MinIO). All four must be set
# to enable backups; if any is empty the scheduler logs "[backup] disabled"
# at boot and the server runs without backups. Recommended: B2 (~6× cheaper
# than S3 for storage, cheap egress). Object key shape:
#   bonsai-backups/YYYY-MM-DD.tar.gz   (one per UTC day, idempotent)
# Retention: anything older than 30 days is pruned by the same job.
# BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# BACKUP_S3_BUCKET=bonsai-backups
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
