# Required — Bonsai uses Claude Sonnet 4.5 for analysis, appeal, and negotiation
ANTHROPIC_API_KEY=sk-ant-...

# Optional — if unset, the email loop uses MockEmailClient (in-memory thread state)
# When set, ResendEmailClient actually delivers outbound mail.
# RESEND_API_KEY=re_...
# RESEND_FROM="Bonsai Appeals <appeals@yourdomain.com>"

# Optional — Svix signing secret for the Resend inbound webhook
# (POST /webhooks/resend-inbound). When set, every inbound is verified
# via constant-time HMAC with a 5-minute replay window.
# Production: REQUIRED — handler returns 500 if NODE_ENV=production and this
# is missing (fail-closed).
# Local dev: handler accepts unsigned payloads with a console warning so you
# can curl the endpoint from a tunnel without round-tripping Svix.
# RESEND_WEBHOOK_SECRET=whsec_...

# Optional — ElevenLabs Conversational AI for real phone dialing
# The simulator works without these; agent-config.ts generates the ElevenLabs JSON
# and client.ts posts it. Twilio number config is provisioned on ElevenLabs side.
# ELEVENLABS_API_KEY=...
# ELEVENLABS_AGENT_ID=...   # optional — create via client.createAgent()
# ELEVENLABS_WEBHOOK_BASE=https://your-tunnel.ngrok.app   # for server_tools callbacks

# Optional — Twilio Programmable Messaging for real SMS delivery.
# Without these, SMS flows run against MockSmsClient (disk-backed thread, simulated
# billing-dept replies). All three must be set to flip to live.
# Inbound SMS arrives via Messaging webhook → POST /api/sms/inbound → mailbox.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+14155551234

# Optional — override HTTP port for the web UI (default 3333)
# PORT=3333
