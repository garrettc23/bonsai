# =============================================================================
# Bonsai — environment variables
# =============================================================================
# Copy this file to `.env` and fill in the REQUIRED keys. Bun auto-loads
# `.env` on `bun run serve`; the file is gitignored so secrets never land
# in version control.
#
# Bonsai is bring-your-own-key for every external service. There are no
# operator-paid defaults — a fresh fork won't accidentally bill someone
# else's account.
# =============================================================================


# =============================================================================
# REQUIRED — Bonsai will not start without these
# =============================================================================

# Your key from https://console.anthropic.com.
# Bonsai uses Claude Opus 4.7 for analysis, appeal drafting, negotiation,
# and comparison. Opus 4.7 requires a paid Anthropic plan.
ANTHROPIC_API_KEY=sk-ant-...

# Your deployed domain, e.g. bonsai.example.com (no protocol, no path).
# Used as a forcing function so a fresh fork doesn't ship someone else's
# domain by accident, and as the canonical public origin for any absolute
# URLs the app emits.
BONSAI_PUBLIC_DOMAIN=bonsai.example.com


# =============================================================================
# OPTIONAL — email negotiation (Resend)
# =============================================================================
# Without these, the email loop runs against MockEmailClient (in-memory
# thread state, no real outbound). Set both to enable real delivery.

# RESEND_API_KEY=re_...
# RESEND_FROM="Bonsai Appeals <appeals@your-domain.com>"

# Svix signing secret for the Resend inbound webhook
# (POST /webhooks/resend-inbound). When set, every inbound is verified
# via constant-time HMAC with a 5-minute replay window.
#   Production: REQUIRED. Handler returns 500 if NODE_ENV=production and
#   this is missing (fail-closed).
#   Local dev: handler accepts unsigned payloads with a console warning
#   so you can curl the endpoint from a tunnel without round-tripping Svix.
# RESEND_WEBHOOK_SECRET=whsec_...

# Unlocks the read-only echo route at
# POST /webhooks/resend-inbound/echo?debug_token=<this-value>. Reports
# whether a signed payload would verify (and how the thread would
# correlate) without mutating any state. Used by
# `scripts/resend-inbound-smoke.sh --echo`. Unset = hard 404.
# BONSAI_WEBHOOK_DEBUG_TOKEN=


# =============================================================================
# OPTIONAL — voice negotiation (ElevenLabs + Twilio)
# =============================================================================
# The simulator (src/voice/simulator.ts) runs whenever any of these is
# unset. All four together flip the orchestrator to real outbound calls.

# ELEVENLABS_API_KEY=...
# ELEVENLABS_TWILIO_PHONE_NUMBER_ID=...     # ID from GET /v1/convai/twilio/phone-numbers
# ELEVENLABS_WEBHOOK_BASE=https://your-tunnel.ngrok.app   # public root; agent posts back to <base>/webhooks/voice/<tool>
# ELEVENLABS_WEBHOOK_SECRET=...             # Bearer secret for inbound server-tool callbacks


# =============================================================================
# OPTIONAL — production deploy
# =============================================================================
# Set these when running on Railway / Fly / any container host.

# Flips on the `Secure` flag on session cookies (HTTPS-only) and
# fail-closed Svix verification on the Resend inbound webhook.
# NODE_ENV=production

# Directory where Bonsai stores SQLite + per-user files. Local dev
# defaults to <repo>/out. In production, point at the mounted persistent
# volume so signups + bills survive deploys.
# BONSAI_DATA_DIR=/app/data

# HTTP port for the web UI. Default 3333.
# PORT=3333


# =============================================================================
# OPTIONAL — observability + limits
# =============================================================================

# Reserved for future error tracking. Currently a no-op.
# SENTRY_DSN=

# Per-user audit cap (sliding-window, daily). Default 5. Each audit
# kicks off Opus 4.7 at ~$0.25–$1.00. Override for staging or paid tiers.
# BONSAI_AUDIT_DAILY_LIMIT=5

# Per-user voice call cap (sliding-window, daily). Default 5.
# BONSAI_VOICE_DAILY_LIMIT=5

# Operator-wide daily ceiling in USD for voice calls. Default 50. The
# dial endpoint refuses to place a call when
# (today_spend + max_estimate) > this cap.
# BONSAI_VOICE_DAILY_BUDGET_USD=50

# When true, /api/voice/dial logs the call it WOULD place and returns a
# synthetic conversation_id without invoking ElevenLabs. Lets agents and
# the smoke script exercise the wiring without burning Twilio minutes.
# VOICE_DRY_RUN=false


# =============================================================================
# OPTIONAL — public branding
# =============================================================================
# Surfaced via GET /api/public-config (unauthenticated) so the SPA, landing
# page, and error pages can render the right "Contact" mailto and copy
# without baking the operator's address into source. OSS forks override
# per-deploy. Unset values render as nothing (the footer link hides itself).

# BONSAI_SUPPORT_EMAIL=support@your-bonsai-domain.com


# =============================================================================
# OPTIONAL — disaster recovery
# =============================================================================
# Nightly tarball backup of $BONSAI_DATA_DIR to any S3-compatible object
# store (Backblaze B2, Cloudflare R2, AWS S3, MinIO). All four must be set
# to enable backups; if any is empty the scheduler logs "[backup] disabled"
# at boot and the server runs without backups. Recommended: B2 (~6× cheaper
# than S3 for storage, cheap egress). Object key shape:
#   bonsai-backups/YYYY-MM-DD.tar.gz   (one per UTC day, idempotent)
# Retention: anything older than 30 days is pruned by the same job.

# BACKUP_S3_ENDPOINT=https://s3.us-west-002.backblazeb2.com
# BACKUP_S3_BUCKET=bonsai-backups
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
